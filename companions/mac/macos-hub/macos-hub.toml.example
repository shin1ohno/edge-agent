# macos-hub configuration
# Copy to macos-hub.toml and adjust as needed.
# All values can be overridden with MACOS_HUB_* env vars.

[mqtt]
host = "localhost"
port = 1883
client_id = "macos-hub"

[macos]
# Unique identifier for this Mac. Used as the {target} segment in
# service/macos/{target}/command/{intent}. Pick something stable and
# memorable: "air", "mac-studio", "imac-office", etc.
edge_id = "mac"

# Seconds between re-publishes of volume / default-output state.
# Set higher for less MQTT chatter, lower for snappier reflection of
# out-of-band changes (e.g. user moved the volume slider in System Settings).
periodic_publish_interval_secs = 5

# MQTT topic structure:
#   service/macos/{edge_id}/state/available_outputs    - JSON array of outputs (retained)
#   service/macos/{edge_id}/state/output_device        - current default output (retained)
#   service/macos/{edge_id}/state/volume               - {"value": 0..100} (retained)
#   service/macos/{edge_id}/state/playback_active      - true/false/null (retained)
#
#   service/macos/{edge_id}/command/play_pause         - empty payload
#   service/macos/{edge_id}/command/next               - empty payload
#   service/macos/{edge_id}/command/previous           - empty payload
#   service/macos/{edge_id}/command/volume             - {"how":"absolute|relative|step","value":N}
#   service/macos/{edge_id}/command/set_output         - {"device_uid":"..."}
#   service/macos/{edge_id}/command/mute               - {"action":"mute|unmute|toggle"}
#
# A target of "all" matches every macos-hub instance.
